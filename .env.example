# ═══════════════════════════════════════════════════════════════════════
# SERVER
# ═══════════════════════════════════════════════════════════════════════
PORT=5000
NODE_ENV=development
BASE_URL=http://localhost:5000

# ═══════════════════════════════════════════════════════════════════════
# DATABASE — 2 cách config
# ═══════════════════════════════════════════════════════════════════════
#
# CÁCH 1 — Production (Railway/Heroku/Aiven): dùng connection string
#   DATABASE_URL=mysql://user:password@host:port/dbname
#   (Railway tự inject biến này khi link MySQL service vào BE service)
#
# CÁCH 2 — Local development: dùng từng env riêng (như cũ)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=backend_db
DB_USER=root
DB_PASSWORD=your_password_here

# ═══════════════════════════════════════════════════════════════════════
# JWT
# ═══════════════════════════════════════════════════════════════════════
# Tạo giá trị ngẫu nhiên mạnh:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_EXPIRES_IN=15m

# ═══════════════════════════════════════════════════════════════════════
# CLIENT URL (Frontend)
# ═══════════════════════════════════════════════════════════════════════
# Dùng cho:
#   - CORS origin
#   - Email verify redirect: {CLIENT_URL}/verify-email-success
#   - Reset password link: {CLIENT_URL}/reset-password?token=...
#
# Local dev:  http://localhost:5173
# Production: https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# ═══════════════════════════════════════════════════════════════════════
# REDIS — 2 cách config
# ═══════════════════════════════════════════════════════════════════════
#
# CÁCH 1 — Production (Railway/Upstash): dùng connection string
#   REDIS_URL=redis://default:password@host:port
#   (Railway tự inject khi link Redis service)
#
# CÁCH 2 — Local development: dùng từng env riêng (như cũ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════
# EMAIL (Nodemailer + Gmail SMTP)
# ═══════════════════════════════════════════════════════════════════════
# Hướng dẫn lấy App Password:
#   1. Bật 2-Step Verification: https://myaccount.google.com/signinoptions/twosv
#   2. Tạo App Password: https://myaccount.google.com/apppasswords
#   3. Copy 16 ký tự (KHÔNG dùng password Gmail thường!)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASSWORD=your_16_char_app_password
EMAIL_FROM_NAME=Backend Project

# ═══════════════════════════════════════════════════════════════════════
# GOOGLE OAUTH
# ═══════════════════════════════════════════════════════════════════════
# Lấy từ Google Cloud Console → APIs & Services → Credentials
# Phải thêm Authorized JavaScript origins:
#   - http://localhost:5173 (dev)
#   - https://your-app.vercel.app (production)
GOOGLE_CLIENT_ID=your_google_client_id_here